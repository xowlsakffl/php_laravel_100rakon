APP_NAME="100rakon"
APP_ENV=local
APP_KEY=
APP_DEBUG=true
APP_URL=http://localhost:8000
APP_ALLOW_IPS=127.0.0.1|::1

LOG_CHANNEL=stack

DB_CONNECTION=mysql
DB_HOST=127.0.0.1
DB_PORT=3306
DB_DATABASE=100rakon
DB_USERNAME=root
DB_PASSWORD=

BROADCAST_DRIVER=log
CACHE_DRIVER=file
QUEUE_CONNECTION=sync
SESSION_DRIVER=file
SESSION_LIFETIME=120

MAIL_DRIVER=smtp
MAIL_HOST=smtp.mailtrap.io
MAIL_PORT=2525
MAIL_USERNAME=
MAIL_PASSWORD=
MAIL_ENCRYPTION=null
MAIL_FROM_ADDRESS=no-reply@example.com
MAIL_FROM_NAME="${APP_NAME}"

TOSS_CLIENT_KEY=
TOSS_SECRET_KEY=
TOSS_WEBHOOK_SECRET=

ALIGO_USER_ID=
ALIGO_API_KEY=
ALIGO_SENDER=
ALIGO_TEST_MODE=Y

SHOP_ADMIN_PHONE=
SHOP_CUSTOMER_CENTER_PHONE=
SHOP_CUSTOMER_CENTER_EMAIL=
SHOP_BANK_ACCOUNT_TEXT="BANK_NAME 000-000000-00000 ACCOUNT_HOLDER"

KAKAO_CLIENT_ID=
KAKAO_CLIENT_SECRET=
KAKAO_REDIRECT_URI="${APP_URL}/social/kakao"
NAVER_CLIENT_ID=
NAVER_CLIENT_SECRET=
NAVER_REDIRECT_URI="${APP_URL}/social/naver"
